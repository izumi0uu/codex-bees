{
  "name": "codex-bees",
  "version": "0.1.0",
  "type": "module",
  "description": "Codex-native multi-agent runtime for explicit local orchestration.",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:izumi0uu/codex-bees.git"
  },
  "exports": {
    ".": "./dist/api.js",
    "./api": "./dist/api.js",
    "./catalog": "./dist/catalog.js",
    "./commands": "./dist/commands.js",
    "./doctor": "./dist/doctor.js",
    "./metadata": "./dist/metadata.js",
    "./mcp": "./dist/mcp.js",
    "./planner": "./dist/planner.js",
    "./runtime-ready": "./dist/runtime-ready.js",
    "./state": "./dist/state.js",
    "./runtime-guidance": "./dist/runtime-guidance.js",
    "./runtime-status": "./dist/runtime-status.js",
    "./runtime-contract": "./dist/runtime-contract.js"
  },
  "main": "dist/api.js",
  "bin": {
    "codex-bees": "./dist/index.js"
  },
  "scripts": {
    "dev": "node ./src/index.js run",
    "build": "node ./scripts/build.mjs",
    "check": "node --check ./src/index.js && node --check ./src/mcp.js && node --check ./scripts/build.mjs && node --check ./scripts/smoke.mjs",
    "smoke": "node ./scripts/smoke.mjs"
  }
}
